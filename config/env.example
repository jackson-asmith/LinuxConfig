# Environment variable reference for LinuxConfig deployment scripts.
#
# Copy this file, fill in real values, and source it before running scripts
# locally — or configure these as GitHub Actions secrets/variables (see below).
#
# GitHub Actions secrets (sensitive — set under Settings > Secrets and variables > Actions):
#   DEPLOY_SSH_KEY
#   AD_JOIN_PASS
#   SATELLITE_ACTIVATION_KEY
#
# GitHub Actions variables (non-sensitive — set under Settings > Secrets and variables > Actions):
#   All others below
#
# Note: HOSTNAME, FQDN, and per-stage skip flags are provided as workflow_dispatch
# inputs at runtime rather than stored variables, since they differ per deployment.

# ── Deployment (deploy.yml) ──────────────────────────────────────────────────
DEPLOY_USER=deploy                    # SSH user on the target host (needs NOPASSWD sudo)
DEPLOY_SSH_KEY=CHANGEME               # SECRET: private key for SSH access to target hosts
DEPLOY_KNOWN_HOST=                    # Output of: ssh-keyscan <target_host>
                                      # If unset, workflow falls back to live keyscan

# ── Base setup (base-setup.sh) ───────────────────────────────────────────────
# HOSTNAME and FQDN are provided as workflow_dispatch inputs at runtime
ADMIN_USER=sysadmin
ADMIN_SSH_KEY=                    # Optional: public key for admin user's authorized_keys
SSH_PORT=22                       # Optional: SSH port (default: 22)
NTP_SERVERS=                      # Optional: space-separated NTP servers (default: AD_SERVER + pool.ntp.org)
FIREWALL_EXTRA_SERVICES=          # Optional: space-separated extra firewalld services to allow
LOGIN_BANNER=                     # Optional: pre-auth login banner text (default: generic authorized-use notice)

# ── Active Directory (ad-join.sh, ad-rejoin-cron.sh) ────────────────────────
AD_DOMAIN=example.com
AD_SERVER=dc-01.example.com
KRB5_REALM=EXAMPLE.COM    # Must be uppercase
AD_JOIN_USER=linux_join   # Service account with domain join rights
AD_JOIN_PASS=CHANGEME     # SECRET — do not commit real value

# ── Satellite (satellite-register.sh) ───────────────────────────────────────
SATELLITE_SERVER=satellite.example.com
SATELLITE_ORG=MyOrg
SATELLITE_ACTIVATION_KEY=CHANGEME   # SECRET — do not commit real value
SATELLITE_ENV=Library               # Optional: Satellite content view environment

# ── AD rejoin cron (ad-rejoin-cron.sh) ──────────────────────────────────────
WHEEL_USER=               # Optional: local user to add to wheel group
REJOIN_SCRIPT=/usr/local/sbin/ad-rejoin.sh   # Default install path
